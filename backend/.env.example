PORT=4000
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/personal_continuity
JWT_SECRET=replace-with-a-long-random-secret
CLIENT_ORIGIN=http://localhost:5173
ASI_ONE_API_KEY=replace-with-your-asi-one-key
ASI_BASE_URL=https://api.asi1.ai/v1
ASI_MODEL=asi1
# Speech-to-text: create this key at console.groq.com.
GROQ_API_KEY=replace-with-your-groq-key
STT_MODEL=whisper-large-v3-turbo
# Text-to-speech: use your Gemini API key from Google AI Studio.
GOOGLE_API_KEY=replace-with-your-gemini-api-key
TTS_MODEL=gemini-2.5-flash-preview-tts
TTS_VOICE=Kore
